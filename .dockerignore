# Virtual environments — the container installs its own dependencies.
venv/
.venv/
virtual_environment/

# llama.cpp binaries — not needed in the API container (runs as a
# separate service in docker-compose).
llama.cpp/

# Git history and IDE files add nothing to the runtime image.
.git/
.github/
.vscode/
.idea/
*.swp
*.swo

# Python caches are rebuilt inside the container.
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Coverage artefacts — test-time only.
htmlcov/
.coverage
coverage.xml

# OS files
.DS_Store
Thumbs.db

# Environment files — configuration is injected via docker-compose or
# environment variables at runtime, not baked into the image.
.env
.env.*

# Test suites — not needed in the production image.
tests/

# Kubernetes manifests — deployment artefacts, not application code.
k8s/

# Documentation and licence files add nothing to the runtime image.
*.md
LICENSE

# Compose and reverse proxy configuration — operational artefacts that
# are consumed by the host orchestrator, not by the container itself.
docker-compose.yml
nginx.conf

# Model files — multi-GB GGUF and Hugging Face model weights must not
# be sent to the Docker build context.
models/

# Claude configuration is not runtime code.
.claude/
