{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/inject_claude_md_before_commit.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/verify_readme_project_structure_includes_added_files.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/verify_no_stale_references_to_renamed_files.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/verify_no_stale_references_to_deleted_files.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/verify_markdown_heading_references_are_hyperlinked.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/verify_no_dead_anchor_links_in_markdown.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/verify_no_import_aliasing_in_python.py"
          }
        ]
      }
    ]
  }
}
